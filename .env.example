# ─────────────────────────────────────────────────────────────
# Required — same value in every process
# ─────────────────────────────────────────────────────────────

# Long-lived team key. Get once from /admin.
MAFIA_STUDIO_KEY=mk_live_XXXX.YYYY

# LLM — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Postgres for the agent's memory + emotion state.
DATABASE_URL=postgres://user:pass@host:5432/mafia_demo

# ─────────────────────────────────────────────────────────────
# Per-persona seat tokens — `npm run bootstrap` mints these.
# ─────────────────────────────────────────────────────────────

SEAT_TOKEN_VERA=eyJhbGciOiJIUzI1NiIs...
SEAT_TOKEN_MARCUS=eyJhbGciOiJIUzI1NiIs...
SEAT_TOKEN_SOFIA=eyJhbGciOiJIUzI1NiIs...
SEAT_TOKEN_THEO=eyJhbGciOiJIUzI1NiIs...

# ─────────────────────────────────────────────────────────────
# Bootstrap-only (not needed at runtime)
# ─────────────────────────────────────────────────────────────

# Basic-auth password for /admin.
ADMIN_PASSWORD=your-organizer-password

# Team UUID — create the team once at /admin, copy its id here.
TEAM_ID=00000000-0000-0000-0000-000000000000

# ─────────────────────────────────────────────────────────────
# Optional overrides (defaults live in src/config.ts)
# ─────────────────────────────────────────────────────────────

# MAFIA_STUDIO_URL=https://your-monitor.up.railway.app
# MAFIA_STUDIO_WS=wss://your-realtime.up.railway.app/ws/seat
# MODEL=anthropic/claude-sonnet-4.6
