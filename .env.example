# MafiaStudio credentials — get from the organizer via /admin + /team.
MAFIA_STUDIO_KEY=mk_live_XXXX.YYYY
SEAT_TOKEN=eyJhbGciOiJIUzI1NiIs...

# Realtime WebSocket endpoint of your MafiaStudio deployment.
MAFIA_STUDIO_WS=wss://your-realtime.up.railway.app/ws/seat

# LLM provider — OpenRouter covers every major model behind one key.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Postgres for the agent's memory + emotion persistence.
# Any Postgres works: Railway, Neon, a local docker container.
DATABASE_URL=postgres://user:pass@host:5432/mafia_demo
