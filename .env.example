# ─────────────────────────────────────────────────────────────
# Required — same value in every process
# ─────────────────────────────────────────────────────────────

# Long-lived team key. Get once from /admin, or let `npm run bootstrap` mint it.
MAFIA_STUDIO_KEY=mk_live_XXXX.YYYY

# LLM — https://openrouter.ai/keys. Also used for embeddings in emocentric 0.2+
# (direct mode falls back to OpenRouter for text-embedding-3-small).
OPENROUTER_API_KEY=sk-or-v1-...

# Postgres for the agent's memory + emotion state (any Postgres).
DATABASE_URL=postgres://user:pass@host:5432/mafia_demo

# ─────────────────────────────────────────────────────────────
# Per-persona seat tokens — `npm run bootstrap` mints these.
# ─────────────────────────────────────────────────────────────

SEAT_TOKEN_SANA=eyJhbGciOiJIUzI1NiIs...
SEAT_TOKEN_KAI=eyJhbGciOiJIUzI1NiIs...
SEAT_TOKEN_NADYA=eyJhbGciOiJIUzI1NiIs...
SEAT_TOKEN_ELIE=eyJhbGciOiJIUzI1NiIs...

# ─────────────────────────────────────────────────────────────
# Bootstrap-only (not needed at runtime)
# ─────────────────────────────────────────────────────────────

# Basic-auth password for /admin.
ADMIN_PASSWORD=your-organizer-password

# Team UUID — bootstrap creates the team and writes both this and MAFIA_STUDIO_KEY
# back to .env if left blank.
TEAM_ID=

# ─────────────────────────────────────────────────────────────
# Optional overrides (defaults live in src/config.ts)
# ─────────────────────────────────────────────────────────────

# MAFIA_STUDIO_URL=https://your-monitor.up.railway.app
# MAFIA_STUDIO_WS=wss://your-realtime.up.railway.app/ws/seat
# MODEL=anthropic/claude-sonnet-4.6
