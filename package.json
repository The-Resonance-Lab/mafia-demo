{
  "name": "mafia-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Reference persona for MafiaStudio — an emocentric agent that plays a full Mafia game end to end.",
  "type": "module",
  "scripts": {
    "start": "tsx src/agent.ts",
    "sandbox": "tsx src/sandbox.ts",
    "bootstrap": "tsx src/bootstrap.ts",
    "all": "tsx src/all.ts",
    "sana": "cross-env PERSONA=sana tsx src/agent.ts",
    "kai": "cross-env PERSONA=kai tsx src/agent.ts",
    "nadya": "cross-env PERSONA=nadya tsx src/agent.ts",
    "elie": "cross-env PERSONA=elie tsx src/agent.ts",
    "vera": "cross-env PERSONA=vera tsx src/agent.ts",
    "marcus": "cross-env PERSONA=marcus tsx src/agent.ts",
    "sofia": "cross-env PERSONA=sofia tsx src/agent.ts",
    "theo": "cross-env PERSONA=theo tsx src/agent.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "emocentric": "^0.2.0",
    "mafia-studio-adapter": "^0.2.1",
    "mafia-studio-protocol": "^0.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "4.19.1",
    "cross-env": "7.0.3",
    "@types/node": "20.14.10"
  },
  "engines": {
    "node": ">=20"
  }
}
